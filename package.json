{
  "name": "ai-cold-mail-agent",
  "version": "1.0.0",
  "description": "AI-powered cold email automation platform",
  "main": "main.js",
  "scripts": {
    "backend-dev": "cd backend && npm run dev",
    "frontend-dev": "cd frontend && npm run dev",
    "backend-install": "cd backend && npm install",
    "frontend-install": "cd frontend && npm install",
    "install-all": "npm run backend-install && npm run frontend-install",
    "app:dev": "concurrently \"npm run frontend-dev\" \"wait-on http://localhost:5173 && electron .\"",
    "app:build:frontend": "cd frontend && npm run build",
    "app:build": "npm run app:build:frontend && electron-builder"
  },
  "keywords": [
    "cold-email",
    "ai",
    "automation",
    "nodejs",
    "react"
  ],
  "author": "Girish Kumar",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^42.3.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.10"
  }
}
